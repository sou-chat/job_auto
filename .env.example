# career-ops — Environment Variables
# Copy this file to .env and fill in your values.
#
#   cp .env.example .env

# ── Gemini Integration (Issue #344) ─────────────────────────────────────────
# Required for: node gemini-eval.mjs "JD text here"
# Free API key: https://aistudio.google.com/apikey
# Free tier: 15 RPM / 1M tokens/day with gemini-2.5-flash (no billing needed)
GEMINI_API_KEY=your_gemini_api_key_here

# ── Optional: Override default Gemini model ───────────────────────────────────
# Default: gemini-2.5-flash (free-tier, fast)
# Alternatives: gemini-1.5-flash, gemini-1.5-pro, gemini-2.5-flash-thinking-exp
# GEMINI_MODEL=gemini-2.5-flash

# ── Apify Integration ────────────────────────────────────────────────────────
# Required for: node scan-apify.mjs (LinkedIn + Indeed India scraping)
# Free account: https://console.apify.com → Account → Integrations → API token
# Free tier: $5 monthly credits — enough for ~10 scans/month across both sources
APIFY_TOKEN=your_apify_token_here

# ── Naukri Integration ────────────────────────────────────────────────────────
# Required for: node scan-naukri.mjs (Playwright headless browser login)
# Naukri blocks all direct API and HTML scraping — a real browser session with
# your credentials is the only reliable way to access job listings.
# Sign up free at: https://www.naukri.com/registration
NAUKRI_EMAIL=your_naukri_email_here
NAUKRI_PASSWORD=your_naukri_password_here
# Optional: override Chrome paths if not in default location
# CHROME_EXE=C:\Program Files\Google\Chrome\Application\chrome.exe
# CHROME_PROFILE=C:\Users\YourName\AppData\Local\Google\Chrome\User Data

# ── Other integrations (add your own below) ──────────────────────────────────
# ANTHROPIC_API_KEY=your_anthropic_key_here   # For Claude-based workflows
# OPENAI_API_KEY=your_openai_key_here          # Future OpenAI integration
